{
  "name": "unplugin-dotnet-wasm",
  "version": "0.0.1",
  "description": "Mount .NET WebAssembly output as virtual modules for Vite, Webpack, Rollup, esbuild, Rspack, Rsbuild, Rolldown, Farm, and Bun.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    },
    "./rollup": {
      "types": "./dist/rollup.d.ts",
      "import": "./dist/rollup.js",
      "require": "./dist/rollup.cjs"
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "import": "./dist/webpack.js",
      "require": "./dist/webpack.cjs"
    },
    "./esbuild": {
      "types": "./dist/esbuild.d.ts",
      "import": "./dist/esbuild.js",
      "require": "./dist/esbuild.cjs"
    },
    "./rspack": {
      "types": "./dist/rspack.d.ts",
      "import": "./dist/rspack.js",
      "require": "./dist/rspack.cjs"
    },
    "./rsbuild": {
      "types": "./dist/rsbuild.d.ts",
      "import": "./dist/rsbuild.js",
      "require": "./dist/rsbuild.cjs"
    },
    "./rolldown": {
      "types": "./dist/rolldown.d.ts",
      "import": "./dist/rolldown.js",
      "require": "./dist/rolldown.cjs"
    },
    "./farm": {
      "types": "./dist/farm.d.ts",
      "import": "./dist/farm.js",
      "require": "./dist/farm.cjs"
    },
    "./bun": {
      "types": "./dist/bun.d.ts",
      "import": "./dist/bun.js",
      "require": "./dist/bun.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "unplugin": "^3.3.0",
    "vite": ">=5.0.0",
    "rolldown": ">=1.0.0",
    "@rspack/core": ">=1.0.0",
    "@rsbuild/core": ">=1.0.0",
    "@farmfe/core": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "rolldown": {
      "optional": true
    },
    "@rspack/core": {
      "optional": true
    },
    "@rsbuild/core": {
      "optional": true
    },
    "@farmfe/core": {
      "optional": true
    }
  },
  "dependencies": {
    "unplugin": "^3.3.0",
    "zod": "^3.23.0"
  }
}
