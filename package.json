{
  "name": "dotnet-wasm-bundler-root",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:plugin": "pnpm --filter unplugin-dotnet-wasm build",
    "build:library:fingerprint": "dotnet build   test/fixtures/Library/Library.csproj -c Debug   -p:WasmFingerprintAssets=true",
    "publish:library:fingerprint": "dotnet publish test/fixtures/Library/Library.csproj -c Release -p:WasmFingerprintAssets=true",
    "build:library:nofingerprint": "dotnet build   test/fixtures/Library/Library.csproj -c Debug   -p:WasmFingerprintAssets=false",
    "publish:library:nofingerprint": "dotnet publish test/fixtures/Library/Library.csproj -c Release -p:WasmFingerprintAssets=false",
    "clean:library": "dotnet clean test/fixtures/Library/Library.csproj -c Debug && dotnet clean test/fixtures/Library/Library.csproj -c Release && node -e \"require('node:fs').rmSync('test/fixtures/Library/bin/Release/net10.0/publish', { recursive: true, force: true })\"",
    "build:sample": "dotnet build samples/SampleLibrary/SampleLibrary.csproj -c Debug && dotnet publish samples/SampleLibrary/SampleLibrary.csproj -c Release",
    "build:sample:vite": "pnpm --filter @dotnet-wasm-bundler/sample-vite build",
    "preview:sample": "pnpm --filter @dotnet-wasm-bundler/sample-vite preview",
    "clean:sample": "dotnet clean samples/SampleLibrary/SampleLibrary.csproj -c Debug && dotnet clean samples/SampleLibrary/SampleLibrary.csproj -c Release",
    "build:fixtures": "node scripts/build-fixtures.js",
    "preview:fixture": "pnpm --filter @dotnet-wasm-bundler/library-app-browser-vite-fixture preview",
    "test:unit": "pnpm --filter unplugin-dotnet-wasm test",
    "test:matrix": "node test/integration/run-test-matrix.mjs",
    "test:dev": "pnpm build:plugin && pnpm build:library:fingerprint && pnpm test:matrix --e2e --serve-mode=server --bundler=vite --platform=browser --fingerprint=true --build-mode=debug",
    "test:debug-fingerprint": "node scripts/run-tests.mjs debug-fingerprint",
    "test:debug-nofingerprint": "node scripts/run-tests.mjs debug-nofingerprint",
    "test:publish-fingerprint": "node scripts/run-tests.mjs publish-fingerprint",
    "test:publish-nofingerprint": "node scripts/run-tests.mjs publish-nofingerprint",
    "test:no-build": "node scripts/run-tests.mjs no-build",
    "test": "node scripts/run-tests.mjs",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "typescript": "^5.5.0"
  }
}
