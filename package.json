{
  "name": "dotnet-wasm-bundler-root",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/**' build",
    "build:plugin": "pnpm --filter unplugin-dotnet-static-assets build",
    "build:library": "dotnet build test/fixtures/Library/Library.csproj -c Debug",
    "build:library:fingerprint": "dotnet build test/fixtures/Library/Library.csproj -c Debug -p:WasmFingerprintAssets=true && dotnet publish test/fixtures/Library/Library.csproj -c Release -p:WasmFingerprintAssets=true",
    "build:library:nofingerprint": "dotnet build test/fixtures/Library/Library.csproj -c Debug -p:WasmFingerprintAssets=false && dotnet publish test/fixtures/Library/Library.csproj -c Release -p:WasmFingerprintAssets=false",
    "clean:library": "dotnet clean test/fixtures/Library/Library.csproj -c Debug && dotnet clean test/fixtures/Library/Library.csproj -c Release && node -e \"require('node:fs').rmSync('test/fixtures/Library/bin/Release/net10.0/publish', { recursive: true, force: true })\"",
    "build:sample": "dotnet build packages/samples/SampleLibrary/SampleLibrary.csproj -c Debug && dotnet publish packages/samples/SampleLibrary/SampleLibrary.csproj -c Release",
    "build:sample:vite": "pnpm --filter @dotnet-wasm-bundler/sample-vite build",
    "preview:sample": "pnpm --filter @dotnet-wasm-bundler/sample-vite preview",
    "clean:sample": "dotnet clean packages/samples/SampleLibrary/SampleLibrary.csproj -c Debug && dotnet clean packages/samples/SampleLibrary/SampleLibrary.csproj -c Release",
    "build:fixture": "pnpm --filter @dotnet-wasm-bundler/library-build-vite-fixture build",
    "build:fixture:vite":     "pnpm --filter @dotnet-wasm-bundler/library-build-vite-fixture     build",
    "build:fixture:rollup":   "pnpm --filter @dotnet-wasm-bundler/library-build-rollup-fixture   build",
    "build:fixture:rolldown": "pnpm --filter @dotnet-wasm-bundler/library-build-rolldown-fixture build",
    "build:fixture:webpack":  "pnpm --filter @dotnet-wasm-bundler/library-build-webpack-fixture  build",
    "build:fixture:rspack":   "pnpm --filter @dotnet-wasm-bundler/library-build-rspack-fixture   build",
    "build:fixture:rsbuild":  "pnpm --filter @dotnet-wasm-bundler/library-build-rsbuild-fixture  build",
    "build:fixture:esbuild":  "pnpm --filter @dotnet-wasm-bundler/library-build-esbuild-fixture  build",
    "build:fixture:farm":     "pnpm --filter @dotnet-wasm-bundler/library-build-farm-fixture     build",
    "build:fixture:bun":      "pnpm --filter @dotnet-wasm-bundler/library-build-bun-fixture      build",
    "build:fixture:all": "pnpm build:fixture:vite && pnpm build:fixture:rollup && pnpm build:fixture:rolldown && pnpm build:fixture:webpack && pnpm build:fixture:rspack && pnpm build:fixture:rsbuild && pnpm build:fixture:esbuild && pnpm build:fixture:farm && pnpm build:fixture:bun",
    "preview:fixture": "pnpm --filter @dotnet-wasm-bundler/library-build-vite-fixture preview",
    "test:unit": "pnpm build:sample && pnpm --filter unplugin-dotnet-static-assets test",
    "test:integration": "pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:fingerprint": "cross-env DOTNET_FIXTURE_SHAPE=fingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:nofingerprint": "cross-env DOTNET_FIXTURE_SHAPE=nofingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:nobuild": "cross-env DOTNET_FIXTURE_SHAPE=none pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:vite:fingerprint":     "cross-env BUNDLER=vite     DOTNET_FIXTURE_SHAPE=fingerprint   pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:vite:nofingerprint":   "cross-env BUNDLER=vite     DOTNET_FIXTURE_SHAPE=nofingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:rollup:fingerprint":   "cross-env BUNDLER=rollup   DOTNET_FIXTURE_SHAPE=fingerprint   pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:rollup:nofingerprint": "cross-env BUNDLER=rollup   DOTNET_FIXTURE_SHAPE=nofingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:rolldown:fingerprint":   "cross-env BUNDLER=rolldown DOTNET_FIXTURE_SHAPE=fingerprint   pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:rolldown:nofingerprint": "cross-env BUNDLER=rolldown DOTNET_FIXTURE_SHAPE=nofingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:webpack:fingerprint":   "cross-env BUNDLER=webpack  DOTNET_FIXTURE_SHAPE=fingerprint   pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:webpack:nofingerprint": "cross-env BUNDLER=webpack  DOTNET_FIXTURE_SHAPE=nofingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:rspack:fingerprint":   "cross-env BUNDLER=rspack   DOTNET_FIXTURE_SHAPE=fingerprint   pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:rspack:nofingerprint": "cross-env BUNDLER=rspack   DOTNET_FIXTURE_SHAPE=nofingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:rsbuild:fingerprint":   "cross-env BUNDLER=rsbuild  DOTNET_FIXTURE_SHAPE=fingerprint   pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:rsbuild:nofingerprint": "cross-env BUNDLER=rsbuild  DOTNET_FIXTURE_SHAPE=nofingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:esbuild:fingerprint":   "cross-env BUNDLER=esbuild  DOTNET_FIXTURE_SHAPE=fingerprint   pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:esbuild:nofingerprint": "cross-env BUNDLER=esbuild  DOTNET_FIXTURE_SHAPE=nofingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:farm:fingerprint":   "cross-env BUNDLER=farm     DOTNET_FIXTURE_SHAPE=fingerprint   pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:farm:nofingerprint": "cross-env BUNDLER=farm     DOTNET_FIXTURE_SHAPE=nofingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:bun:fingerprint":   "cross-env BUNDLER=bun      DOTNET_FIXTURE_SHAPE=fingerprint   pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:bun:nofingerprint": "cross-env BUNDLER=bun      DOTNET_FIXTURE_SHAPE=nofingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test",
    "test:integration:all:fingerprint":   "pnpm test:integration:vite:fingerprint   && pnpm test:integration:rollup:fingerprint   && pnpm test:integration:rolldown:fingerprint   && pnpm test:integration:webpack:fingerprint   && pnpm test:integration:rspack:fingerprint   && pnpm test:integration:rsbuild:fingerprint   && pnpm test:integration:esbuild:fingerprint   && pnpm test:integration:farm:fingerprint   && pnpm test:integration:bun:fingerprint",
    "test:integration:all:nofingerprint": "pnpm test:integration:vite:nofingerprint && pnpm test:integration:rollup:nofingerprint && pnpm test:integration:rolldown:nofingerprint && pnpm test:integration:webpack:nofingerprint && pnpm test:integration:rspack:nofingerprint && pnpm test:integration:rsbuild:nofingerprint && pnpm test:integration:esbuild:nofingerprint && pnpm test:integration:farm:nofingerprint && pnpm test:integration:bun:nofingerprint",
    "test:e2e": "pnpm --filter @dotnet-wasm-bundler/integration-tests test:e2e",
    "test:e2e:vite:fingerprint":     "cross-env BUNDLER=vite     DOTNET_FIXTURE_SHAPE=fingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test:e2e",
    "test:e2e:vite:nofingerprint":   "cross-env BUNDLER=vite     DOTNET_FIXTURE_SHAPE=nofingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test:e2e",
    "test:e2e:rollup:fingerprint":   "cross-env BUNDLER=rollup   DOTNET_FIXTURE_SHAPE=fingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test:e2e",
    "test:e2e:rollup:nofingerprint": "cross-env BUNDLER=rollup   DOTNET_FIXTURE_SHAPE=nofingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test:e2e",
    "test:e2e:rolldown:fingerprint":   "cross-env BUNDLER=rolldown DOTNET_FIXTURE_SHAPE=fingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test:e2e",
    "test:e2e:rolldown:nofingerprint": "cross-env BUNDLER=rolldown DOTNET_FIXTURE_SHAPE=nofingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test:e2e",
    "test:e2e:webpack:fingerprint":   "cross-env BUNDLER=webpack  DOTNET_FIXTURE_SHAPE=fingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test:e2e",
    "test:e2e:webpack:nofingerprint": "cross-env BUNDLER=webpack  DOTNET_FIXTURE_SHAPE=nofingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test:e2e",
    "test:e2e:rspack:fingerprint":   "cross-env BUNDLER=rspack   DOTNET_FIXTURE_SHAPE=fingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test:e2e",
    "test:e2e:rspack:nofingerprint": "cross-env BUNDLER=rspack   DOTNET_FIXTURE_SHAPE=nofingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test:e2e",
    "test:e2e:rsbuild:fingerprint":   "cross-env BUNDLER=rsbuild  DOTNET_FIXTURE_SHAPE=fingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test:e2e",
    "test:e2e:rsbuild:nofingerprint": "cross-env BUNDLER=rsbuild  DOTNET_FIXTURE_SHAPE=nofingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test:e2e",
    "test:e2e:esbuild:fingerprint":   "cross-env BUNDLER=esbuild  DOTNET_FIXTURE_SHAPE=fingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test:e2e",
    "test:e2e:esbuild:nofingerprint": "cross-env BUNDLER=esbuild  DOTNET_FIXTURE_SHAPE=nofingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test:e2e",
    "test:e2e:farm:fingerprint":   "cross-env BUNDLER=farm     DOTNET_FIXTURE_SHAPE=fingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test:e2e",
    "test:e2e:farm:nofingerprint": "cross-env BUNDLER=farm     DOTNET_FIXTURE_SHAPE=nofingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test:e2e",
    "test:e2e:bun:fingerprint":   "cross-env BUNDLER=bun      DOTNET_FIXTURE_SHAPE=fingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test:e2e",
    "test:e2e:bun:nofingerprint": "cross-env BUNDLER=bun      DOTNET_FIXTURE_SHAPE=nofingerprint pnpm --filter @dotnet-wasm-bundler/integration-tests test:e2e",
    "test:e2e:all:fingerprint":   "pnpm test:e2e:vite:fingerprint   && pnpm test:e2e:rollup:fingerprint   && pnpm test:e2e:rolldown:fingerprint   && pnpm test:e2e:webpack:fingerprint   && pnpm test:e2e:rspack:fingerprint   && pnpm test:e2e:rsbuild:fingerprint   && pnpm test:e2e:esbuild:fingerprint   && pnpm test:e2e:farm:fingerprint   && pnpm test:e2e:bun:fingerprint",
    "test:e2e:all:nofingerprint": "pnpm test:e2e:vite:nofingerprint && pnpm test:e2e:rollup:nofingerprint && pnpm test:e2e:rolldown:nofingerprint && pnpm test:e2e:webpack:nofingerprint && pnpm test:e2e:rspack:nofingerprint && pnpm test:e2e:rsbuild:nofingerprint && pnpm test:e2e:esbuild:nofingerprint && pnpm test:e2e:farm:nofingerprint && pnpm test:e2e:bun:nofingerprint",
    "test:e2e:all": "pnpm test:e2e:all:fingerprint && pnpm test:e2e:all:nofingerprint",
    "test:fingerprint-enabled": "pnpm clean:library && pnpm build:plugin && pnpm build:library:fingerprint && pnpm build:fixture && pnpm test:unit && pnpm test:integration:fingerprint && pnpm test:e2e",
    "test:fingerprint-disabled": "pnpm clean:library && pnpm build:plugin && pnpm build:library:nofingerprint && pnpm build:fixture && pnpm test:unit && pnpm test:integration:nofingerprint && pnpm test:e2e",
    "test:no-build": "pnpm clean:library && pnpm build:plugin && pnpm test:integration:nobuild",
    "test": "pnpm test:no-build && pnpm test:fingerprint-enabled && pnpm test:fingerprint-disabled",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "typescript": "^5.5.0"
  }
}
